<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.districthub.ui.AboutController"
      styleClass="main-content">

    <HBox styleClass="content-header" alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label text="About GamesHub" styleClass="content-title"/>
            <Label text="Open format · No lock-in · Your data, your district" styleClass="content-subtitle"/>
        </VBox>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="cards-scroll">
        <VBox spacing="20" styleClass="settings-body">

            <!-- Identity -->
            <VBox styleClass="card" spacing="14">
                <Label text="What Is GamesHub?" styleClass="card-title"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="GamesHub is a local-first desktop application that aggregates athletic schedule and score data from the platforms your district already uses — Arbiter, MaxPreps, and others — into a single unified view. It runs entirely on your machine. No cloud account, no subscription, no third-party server ever receives your data."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="Version 1.0 · Built for athletic directors, administrators, and coaches who are tired of logging into six platforms to answer one question."/>
            </VBox>

            <!-- Open Format -->
            <VBox styleClass="card" spacing="14">
                <Label text="Open Data Format" styleClass="card-title"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="All data synchronized by GamesHub is stored locally in an open SQLite database file located at:"/>
                <Label text="~/.gameshub/gameshub.db" style="-fx-font-family: monospace; -fx-text-fill: #A78BFA; -fx-font-size: 13px;"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="SQLite is a public-domain, industry-standard file format readable by hundreds of tools — DB Browser for SQLite, Excel (via ODBC), Python pandas, R, and more. You are never dependent on District Hub to access your own data."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="Every game record, sync log entry, and platform configuration is stored in plain relational tables with no proprietary encoding. The schema is intentionally simple and documented below."/>

                <!-- Schema table -->
                <VBox spacing="6" style="-fx-background-color: #0F1117; -fx-background-radius: 8; -fx-padding: 16;">
                    <Label text="DATABASE SCHEMA" style="-fx-text-fill: #4A5568; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label text="games           — id, game_date, game_time, home_team, away_team, sport, level, location, home_score, away_score, status, sources, created_at, updated_at" styleClass="card-desc" wrapText="true" style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
                    <Label text="sync_log        — id, level, platform, message, created_at" styleClass="card-desc" wrapText="true" style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
                    <Label text="platform_config — platform, endpoint, mode, trained, school_name" styleClass="card-desc" wrapText="true" style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
                    <Label text="app_settings    — key, value" styleClass="card-desc" wrapText="true" style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
                </VBox>

                <Label wrapText="true" styleClass="card-desc"
                    text="Use the Export CSV button on the Schedule or Scores tab at any time to extract data in comma-separated format compatible with any spreadsheet application."/>
            </VBox>

            <!-- No Vendor Lock-In -->
            <VBox styleClass="card" spacing="14">
                <Label text="No Vendor Lock-In" styleClass="card-title"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="GamesHub does not store data in any proprietary format. If you stop using this application tomorrow, your data remains fully accessible. You can:"/>
                <VBox spacing="6" style="-fx-padding: 0 0 0 12;">
                    <Label text="·  Open the SQLite file directly with any compatible tool" styleClass="card-desc"/>
                    <Label text="·  Export all records to CSV from within the app at any time" styleClass="card-desc"/>
                    <Label text="·  Migrate to any other system without format conversion" styleClass="card-desc"/>
                    <Label text="·  Delete the application and retain full access to your data" styleClass="card-desc"/>
                </VBox>
                <Label wrapText="true" styleClass="card-desc"
                    text="The connectors that read from third-party platforms (Arbiter, MaxPreps, etc.) use only the same authenticated session your browser would use. No special API agreements, no vendor contracts, and no data is transmitted anywhere other than between your machine and the platform's own servers."/>
            </VBox>

            <!-- Disclaimer -->
            <VBox styleClass="card" spacing="14">
                <Label text="Disclaimer &amp; Terms of Use" styleClass="card-title"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="GamesHub is an independent tool and is not affiliated with, endorsed by, or in any way officially connected to Arbiter Sports, MaxPreps, FanX / Snap Interactive, Rank One Sport, FusionPoint, Bound, Vantage / League Minder, Dragonfly Athletics, or HomeCampus. All platform names, trademarks, and logos are the property of their respective owners."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="This software reads data from platforms solely on behalf of authenticated users who have lawful access to that data through their own institutional accounts. It does not circumvent authentication, access data belonging to other institutions, or transmit collected data to any external service."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="Users are solely responsible for ensuring their use of GamesHub complies with the terms of service of each connected platform, applicable data privacy laws (FERPA, state equivalents), and their institution's acceptable use policies. The authors of this software accept no liability for misuse, data loss, or any damages arising from use of this application."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="THIS SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, AND NON-INFRINGEMENT. IN NO EVENT SHALL THE AUTHORS BE LIABLE FOR ANY CLAIM, DAMAGES, OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT, OR OTHERWISE, ARISING FROM, OUT OF, OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE."/>
            </VBox>

            <!-- Privacy -->
            <VBox styleClass="card" spacing="14">
                <Label text="Privacy" styleClass="card-title"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="GamesHub collects no telemetry, usage analytics, crash reports, or personal information of any kind. The application has no network connectivity except to the platform URLs you explicitly configure and connect to. No data ever leaves your machine except as part of the normal authenticated requests to those platforms."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="Platform session cookies are stored locally in an encrypted session store at ~/.gameshub/sessions/. These are equivalent to the cookies your browser stores when you log into those platforms and are never transmitted to any third party."/>
            </VBox>

            <!-- Open Source -->
            <VBox styleClass="card" spacing="14">
                <Label text="Licensing &amp; Source" styleClass="card-title"/>
                <Label wrapText="true" styleClass="card-desc"
                    text="GamesHub is released under the MIT License. You are free to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the software, subject to the terms of that license."/>
                <Label wrapText="true" styleClass="card-desc"
                    text="The MIT License was chosen deliberately: it is the most permissive widely-recognized open source license, ensuring that districts, developers, and vendors can build on this work without restriction. A copy of the full license text is included with the application distribution."/>
            </VBox>

            <VBox minHeight="24"/>
        </VBox>
    </ScrollPane>
</VBox>
