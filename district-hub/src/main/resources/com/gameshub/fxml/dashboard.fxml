<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gameshub.ui.DashboardController"
      styleClass="main-content">

    <HBox styleClass="content-header" alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="2">
            <Label text="Schedule" styleClass="content-title"/>
            <Label text="All upcoming and past games across platforms" styleClass="content-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox styleClass="filter-bar" spacing="12" alignment="CENTER_LEFT">
        <Label text="Filter:" styleClass="filter-label"/>
        <ComboBox fx:id="sportFilter" promptText="All Sports" styleClass="filter-combo"/>
        <ComboBox fx:id="levelFilter" promptText="All Levels" styleClass="filter-combo"/>
        <ComboBox fx:id="platformFilter" promptText="All Platforms" styleClass="filter-combo"/>
        <Label text="From:" styleClass="filter-label"/>
        <DatePicker fx:id="dateFrom" styleClass="filter-combo"/>
        <Label text="To:" styleClass="filter-label"/>
        <DatePicker fx:id="dateTo" styleClass="filter-combo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Game" styleClass="btn-primary" onAction="#onAddGame"/>
        <Button text="Export CSV" styleClass="btn-secondary" onAction="#onExportCSV"/>
    </HBox>

    <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colDate" text="DATE" prefWidth="110"/>
            <TableColumn fx:id="colTime" text="TIME" prefWidth="80"/>
            <TableColumn fx:id="colHome" text="HOME TEAM" prefWidth="220"/>
            <TableColumn fx:id="colAway" text="AWAY TEAM" prefWidth="220"/>
            <TableColumn fx:id="colSport" text="SPORT" prefWidth="120"/>
            <TableColumn fx:id="colLevel" text="LEVEL" prefWidth="120"/>
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="100"/>
            <TableColumn fx:id="colLocation" text="LOCATION" prefWidth="180"/>
            <TableColumn fx:id="colSource" text="SOURCE" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox styleClass="status-bar" spacing="16" alignment="CENTER_LEFT">
        <Label fx:id="connectedCount" text="0 / 6 platforms connected" styleClass="status-bar-text"/>
        <Label text="|" styleClass="status-bar-divider"/>
        <Label fx:id="lastSyncLabel" text="Last sync: Never" styleClass="status-bar-text"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="nextSyncLabel" text="Next sync: --" styleClass="status-bar-muted"/>
    </HBox>
</VBox>
