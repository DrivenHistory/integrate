<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.districthub.ui.TeamsController"
      styleClass="main-content">

    <HBox styleClass="content-header" alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="2">
            <Label text="Teams" styleClass="content-title"/>
            <Label text="Unique teams across all synced games" styleClass="content-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="syncStatusLabel" text="" styleClass="sync-status-text"/>
        <Button text="Sync Now" styleClass="btn-primary" onAction="#onSyncNow"/>
    </HBox>

    <TableView fx:id="teamsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colTeamName" text="TEAM" prefWidth="300"/>
            <TableColumn fx:id="colTeamSport" text="SPORT" prefWidth="160"/>
            <TableColumn fx:id="colTeamLevel" text="LEVEL" prefWidth="140"/>
            <TableColumn fx:id="colTeamGames" text="GAMES" prefWidth="80"/>
        </columns>
    </TableView>
</VBox>
